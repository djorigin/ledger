# --- Django ---
# Generate a fresh value -- never reuse the dev secret key.
# e.g. python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-freshly-generated-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.example.com
# Flip to True once a real domain + TLS cert sit in front of nginx -- see
# config/settings/prod.py. Leave False for the first deploy (port 80 only).
DJANGO_USE_HTTPS=False

# --- CORS ---
# Not needed in production: nginx serves the SPA and proxies the API on
# the same origin, so the browser never makes a cross-origin request.
CORS_ALLOWED_ORIGINS=

# --- Postgres ---
POSTGRES_DB=ledger
POSTGRES_USER=ledger
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://ledger:change-me@postgres:5432/ledger

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
